{
	"info": {
		"_postman_id": "YOUR_POSTMAN_COLLECTION_ID",
		"name": "Controle Financeiro API - Transações",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_collection_link": "YOUR_POSTMAN_SHARE_LINK"
	},
	"item": [
		{
			"name": "Transactions",
			"item": [
				{
					"name": "GET All Transactions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/api/transactions",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions"
							]
						},
						"description": "Lista todas as transações, com opção de filtros por query params."
					},
					"response": []
				},
				{
					"name": "GET Transactions with Filters (Example)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/api/transactions?type=expense&category=Alimentação&startDate=2026-01-01&endDate=2026-01-31",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions"
							],
							"query": [
								{
									"key": "type",
									"value": "expense",
									"description": "Filtrar por tipo (income/expense)"
								},
								{
									"key": "category",
									"value": "Alimentação",
									"description": "Filtrar por categoria"
								},
								{
									"key": "startDate",
									"value": "2026-01-01",
									"description": "Data de início (YYYY-MM-DD)"
								},
								{
									"key": "endDate",
									"value": "2026-01-31",
									"description": "Data de fim (YYYY-MM-DD)"
								}
							]
						},
						"description": "Exemplo de listagem de transações filtradas por tipo, categoria e período."
					},
					"response": []
				},
				{
					"name": "GET Single Transaction by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/api/transactions/{{transactionId}}",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions",
								"{{transactionId}}"
							]
						},
						"description": "Obtém uma única transação pelo seu ID. Use um ID válido que você criou anteriormente."
					},
					"response": []
				},
				{
					"name": "POST Create Transaction",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate a unique ID if not provided, useful for test data",
									"// This example uses a simple placeholder, replace with actual UUID generation if needed in client side",
									"// For Next.js API, ID is generated on server side if not provided.",
									"// pm.environment.set("transactionId", pm.variables.replaceIn("{{$guid}}"));"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (pm.response.code === 200 && jsonData && jsonData.data && jsonData.data.id) {",
									"    pm.environment.set("transactionId", jsonData.data.id);",
									"    console.log("transactionId set to: " + jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{
    "type": "expense",
    "description": "Almoço de negócios",
    "value": 75.50,
    "date": "2026-01-29",
    "category": "Alimentação",
    "responsible": "Alexandre"
}"
						},
						"url": {
							"raw": "{{baseURL}}/api/transactions",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions"
							]
						},
						"description": "Cria uma nova transação. Após a criação bem-sucedida, o `transactionId` retornado é salvo como variável de ambiente para uso em PUT/DELETE."
					},
					"response": []
				},
				{
					"name": "POST Create Installment Transaction (Example)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (pm.response.code === 200 && jsonData && jsonData.data && jsonData.data.id) {",
									"    pm.environment.set("installmentParentId", jsonData.data.id);",
									"    console.log("installmentParentId set to: " + jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{
    "type": "expense",
    "description": "Parcela Mensal - Carro",
    "value": 500.00,
    "date": "2026-01-29",
    "category": "Transporte",
    "responsible": "Alexandre",
    "installment_number": 1,
    "total_installments": 12,
    "is_recurring": true
}"
						},
						"url": {
							"raw": "{{baseURL}}/api/transactions",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions"
							]
						},
						"description": "Cria uma transação com detalhes de parcela. O `installmentParentId` é salvo para referência."
					},
					"response": []
				},
				{
					"name": "PUT Update Transaction by ID",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{
    "description": "Almoço de negócios (atualizado)",
    "value": 80.00,
    "paid": true
}"
						},
						"url": {
							"raw": "{{baseURL}}/api/transactions/{{transactionId}}",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions",
								"{{transactionId}}"
							]
						},
						"description": "Atualiza uma transação existente. Requer o `transactionId` obtido da requisição POST."
					},
					"response": []
				},
				{
					"name": "DELETE Transaction by ID",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/api/transactions/{{transactionId}}",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions",
								"{{transactionId}}"
							]
						},
						"description": "Deleta uma transação existente. Requer o `transactionId` obtido da requisição POST."
					},
					"response": []
				},
				{
					"name": "GET Summary of Transactions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/api/transactions/summary",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions",
								"summary"
							]
						},
						"description": "Obtém um sumário financeiro (receita, despesa, saldo) para todas as transações."
					},
					"response": []
				},
				{
					"name": "GET Summary with Filters (Example)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/api/transactions/summary?type=expense&startDate=2026-01-01&endDate=2026-01-31",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"api",
								"transactions",
								"summary"
							],
							"query": [
								{
									"key": "type",
									"value": "expense",
									"description": "Filtrar por tipo (income/expense)"
								},
								{
									"key": "startDate",
									"value": "2026-01-01",
									"description": "Data de início (YYYY-MM-DD)"
								},
								{
									"key": "endDate",
									"value": "2026-01-31",
									"description": "Data de fim (YYYY-MM-DD)"
								}
							]
						},
						"description": "Obtém um sumário financeiro filtrado."
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseURL",
			"value": "http://localhost:3000",
			"type": "string",
			"description": "URL base da sua API Next.js (ex: http://localhost:3000 ou https://your-app.vercel.app)"
		},
		{
			"key": "transactionId",
			"value": "",
			"type": "string",
			"description": "ID da transação criado por um POST, usado para PUT e DELETE"
		},
		{
			"key": "installmentParentId",
			"value": "",
			"type": "string",
			"description": "ID da transação pai para parcelamentos, criado por um POST de parcela"
		}
	]
}